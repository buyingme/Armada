{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Star Wars: Armada Component Catalog Schema",
    "description": "Schema contract for static ship, squadron, upgrade, objective, obstacle, and rules-reference records used by the fleet builder. Runtime game logic reads static card facts from these JSON records rather than hardcoded GDScript values.",
    "oneOf": [
        {
            "$ref": "#/definitions/ship_card"
        },
        {
            "$ref": "#/definitions/squadron_card"
        },
        {
            "$ref": "#/definitions/upgrade_card"
        },
        {
            "$ref": "#/definitions/objective_card"
        },
        {
            "$ref": "#/definitions/obstacle_component"
        },
        {
            "$ref": "#/definitions/rules_reference"
        }
    ],
    "definitions": {
        "faction": {
            "type": "string",
            "enum": [
                "REBEL_ALLIANCE",
                "GALACTIC_EMPIRE",
                "DUAL",
                "NEUTRAL"
            ]
        },
        "ship_size": {
            "type": "string",
            "enum": [
                "SMALL",
                "MEDIUM",
                "LARGE",
                "HUGE"
            ]
        },
        "dice_color": {
            "type": "string",
            "enum": [
                "RED",
                "BLUE",
                "BLACK"
            ]
        },
        "defense_token": {
            "type": "string",
            "enum": [
                "EVADE",
                "REDIRECT",
                "BRACE",
                "SCATTER",
                "CONTAIN",
                "SALVO"
            ]
        },
        "upgrade_slot": {
            "type": "string",
            "enum": [
                "COMMANDER",
                "TITLE",
                "OFFICER",
                "WEAPONS_TEAM",
                "SUPPORT_TEAM",
                "OFFENSIVE_RETROFIT",
                "DEFENSIVE_RETROFIT",
                "ORDNANCE",
                "ION_CANNONS",
                "TURBOLASERS",
                "FLEET_COMMAND",
                "FLEET_SUPPORT",
                "EXPERIMENTAL_RETROFIT",
                "SUPER_WEAPON"
            ]
        },
        "objective_category": {
            "type": "string",
            "enum": [
                "ASSAULT",
                "DEFENSE",
                "NAVIGATION"
            ]
        },
        "rules_integration_status": {
            "type": "string",
            "enum": [
                "NOT_INTEGRATED",
                "PARTIAL",
                "INTEGRATED"
            ]
        },
        "rules_scope": {
            "type": "string",
            "enum": [
                "GENERIC",
                "COMPONENT_SPECIFIC"
            ]
        },
        "string_array": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "note_array": {
            "type": "array",
            "items": {
                "oneOf": [
                    {
                        "type": "string"
                    },
                    {
                        "type": "object",
                        "additionalProperties": true
                    }
                ]
            }
        },
        "dice_pool": {
            "type": "object",
            "description": "A pool of attack dice expressed as count per color. Only include colors with count > 0.",
            "properties": {
                "RED": {
                    "type": "integer",
                    "minimum": 0
                },
                "BLUE": {
                    "type": "integer",
                    "minimum": 0
                },
                "BLACK": {
                    "type": "integer",
                    "minimum": 0
                }
            },
            "additionalProperties": false
        },
        "yaw_row": {
            "type": "array",
            "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
            }
        },
        "rules_integration": {
            "type": "object",
            "required": [
                "status",
                "implemented_rule_ids",
                "pending_rule_surfaces",
                "notes"
            ],
            "properties": {
                "status": {
                    "$ref": "#/definitions/rules_integration_status"
                },
                "implemented_rule_ids": {
                    "$ref": "#/definitions/string_array"
                },
                "pending_rule_surfaces": {
                    "$ref": "#/definitions/string_array"
                },
                "notes": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "rule_surface": {
            "type": "object",
            "required": [
                "kind",
                "surface",
                "timing",
                "summary"
            ],
            "properties": {
                "kind": {
                    "type": "string"
                },
                "surface": {
                    "type": "string"
                },
                "timing": {
                    "type": "string"
                },
                "summary": {
                    "type": "string"
                }
            },
            "additionalProperties": true
        },
        "common_catalog_metadata": {
            "type": "object",
            "properties": {
                "_comment": {
                    "type": "string"
                },
                "_source": {
                    "type": "string"
                },
                "_status": {
                    "type": "string"
                },
                "data_key": {
                    "type": "string"
                },
                "kind": {
                    "type": "string"
                },
                "wave": {
                    "type": "integer",
                    "minimum": 0
                },
                "expansion": {
                    "type": "string"
                },
                "available_through": {
                    "$ref": "#/definitions/string_array"
                },
                "card_image": {
                    "type": "string"
                },
                "alternate_images": {
                    "$ref": "#/definitions/string_array"
                },
                "token_image": {
                    "type": "string"
                },
                "rules_source": {
                    "type": "string"
                },
                "search_tags": {
                    "$ref": "#/definitions/string_array"
                },
                "source_refs": {
                    "$ref": "#/definitions/string_array"
                },
                "rules_reference_ids": {
                    "$ref": "#/definitions/string_array"
                },
                "rules_integration": {
                    "$ref": "#/definitions/rules_integration"
                },
                "rule_surfaces": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/rule_surface"
                    }
                },
                "runtime_state_requirements": {
                    "$ref": "#/definitions/string_array"
                }
            },
            "additionalProperties": true
        },
        "ship_card": {
            "allOf": [
                {
                    "$ref": "#/definitions/common_catalog_metadata"
                },
                {
                    "type": "object",
                    "required": [
                        "data_key",
                        "kind",
                        "ship_name",
                        "faction",
                        "ship_size",
                        "point_cost",
                        "hull",
                        "command_value",
                        "squadron_value",
                        "engineering_value",
                        "max_speed",
                        "shields",
                        "battery_armament",
                        "anti_squadron_armament",
                        "defense_tokens",
                        "upgrade_slots",
                        "navigation_chart"
                    ],
                    "properties": {
                        "kind": {
                            "const": "ship_card"
                        },
                        "ship_name": {
                            "type": "string"
                        },
                        "faction": {
                            "$ref": "#/definitions/faction"
                        },
                        "ship_size": {
                            "$ref": "#/definitions/ship_size"
                        },
                        "point_cost": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "hull": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "command_value": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "squadron_value": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "engineering_value": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "max_speed": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "ship_class": {
                            "type": "string"
                        },
                        "ship_variant": {
                            "type": "string"
                        },
                        "title_upgrade_group": {
                            "type": "string"
                        },
                        "related_ship_data_keys": {
                            "$ref": "#/definitions/string_array"
                        },
                        "class_specifics": {
                            "type": "string"
                        },
                        "lore_aliases": {
                            "$ref": "#/definitions/string_array"
                        },
                        "shields": {
                            "type": "object",
                            "required": [
                                "FRONT",
                                "LEFT",
                                "RIGHT",
                                "REAR"
                            ],
                            "properties": {
                                "FRONT": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "LEFT": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "RIGHT": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "REAR": {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            },
                            "additionalProperties": false
                        },
                        "battery_armament": {
                            "type": "object",
                            "required": [
                                "FRONT",
                                "LEFT",
                                "RIGHT",
                                "REAR"
                            ],
                            "properties": {
                                "FRONT": {
                                    "$ref": "#/definitions/dice_pool"
                                },
                                "LEFT": {
                                    "$ref": "#/definitions/dice_pool"
                                },
                                "RIGHT": {
                                    "$ref": "#/definitions/dice_pool"
                                },
                                "REAR": {
                                    "$ref": "#/definitions/dice_pool"
                                }
                            },
                            "additionalProperties": false
                        },
                        "anti_squadron_armament": {
                            "$ref": "#/definitions/dice_pool"
                        },
                        "defense_tokens": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/defense_token"
                            }
                        },
                        "upgrade_slots": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/upgrade_slot"
                            }
                        },
                        "navigation_chart": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/yaw_row"
                            }
                        }
                    },
                    "additionalProperties": true
                }
            ]
        },
        "squadron_keyword": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "value": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "additionalProperties": false
        },
        "squadron_card": {
            "allOf": [
                {
                    "$ref": "#/definitions/common_catalog_metadata"
                },
                {
                    "type": "object",
                    "required": [
                        "data_key",
                        "kind",
                        "squadron_name",
                        "faction",
                        "point_cost",
                        "hull",
                        "speed",
                        "anti_squadron_armament",
                        "battery_armament",
                        "keywords",
                        "is_unique",
                        "defense_tokens",
                        "rules_reference_ids",
                        "rules_integration"
                    ],
                    "properties": {
                        "kind": {
                            "const": "squadron_card"
                        },
                        "squadron_name": {
                            "type": "string"
                        },
                        "faction": {
                            "$ref": "#/definitions/faction"
                        },
                        "point_cost": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "hull": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "speed": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "squadron_family": {
                            "type": "string"
                        },
                        "ace_variants": {
                            "$ref": "#/definitions/string_array"
                        },
                        "anti_squadron_armament": {
                            "$ref": "#/definitions/dice_pool"
                        },
                        "battery_armament": {
                            "$ref": "#/definitions/dice_pool"
                        },
                        "keywords": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/squadron_keyword"
                            }
                        },
                        "keyword_reminder_text": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        },
                        "ability_text": {
                            "type": "string"
                        },
                        "is_unique": {
                            "type": "boolean"
                        },
                        "unique_group": {
                            "type": "string"
                        },
                        "defense_tokens": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/defense_token"
                            }
                        }
                    },
                    "additionalProperties": true
                }
            ]
        },
        "upgrade_card": {
            "allOf": [
                {
                    "$ref": "#/definitions/common_catalog_metadata"
                },
                {
                    "type": "object",
                    "required": [
                        "data_key",
                        "kind",
                        "upgrade_name",
                        "upgrade_type",
                        "wave",
                        "expansion",
                        "available_through",
                        "card_image",
                        "point_cost",
                        "is_unique",
                        "unique_group",
                        "faction_restriction",
                        "size_restriction",
                        "ship_class_restriction",
                        "ship_data_key_restriction",
                        "is_exhaustible",
                        "is_modification",
                        "effect_text",
                        "rules_reference_ids",
                        "rules_integration",
                        "rule_surfaces",
                        "runtime_state_requirements",
                        "search_tags",
                        "source_refs"
                    ],
                    "properties": {
                        "kind": {
                            "const": "upgrade_card"
                        },
                        "upgrade_name": {
                            "type": "string"
                        },
                        "upgrade_type": {
                            "$ref": "#/definitions/upgrade_slot"
                        },
                        "point_cost": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "is_unique": {
                            "type": "boolean"
                        },
                        "unique_group": {
                            "type": "string"
                        },
                        "faction_restriction": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/faction"
                            }
                        },
                        "size_restriction": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/ship_size"
                            }
                        },
                        "ship_class_restriction": {
                            "$ref": "#/definitions/string_array"
                        },
                        "ship_data_key_restriction": {
                            "$ref": "#/definitions/string_array"
                        },
                        "is_exhaustible": {
                            "type": "boolean"
                        },
                        "is_modification": {
                            "type": "boolean"
                        },
                        "effect_text": {
                            "type": "string"
                        },
                        "timing_notes": {
                            "$ref": "#/definitions/note_array"
                        },
                        "errata": {
                            "$ref": "#/definitions/note_array"
                        },
                        "clarifications": {
                            "$ref": "#/definitions/note_array"
                        }
                    },
                    "additionalProperties": true
                }
            ]
        },
        "objective_tokens": {
            "type": "object",
            "required": [
                "uses_tokens",
                "count",
                "count_formula",
                "placement"
            ],
            "properties": {
                "uses_tokens": {
                    "type": "boolean"
                },
                "count": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "count_formula": {
                    "type": "string"
                },
                "placement": {
                    "$ref": "#/definitions/string_array"
                }
            },
            "additionalProperties": true
        },
        "objective_card": {
            "allOf": [
                {
                    "$ref": "#/definitions/common_catalog_metadata"
                },
                {
                    "type": "object",
                    "required": [
                        "data_key",
                        "kind",
                        "objective_name",
                        "category",
                        "wave",
                        "expansion",
                        "available_through",
                        "card_image",
                        "victory_token_points",
                        "task_force_recommended",
                        "setup_text",
                        "special_rule_text",
                        "end_of_round_text",
                        "end_of_game_text",
                        "timing_notes",
                        "errata",
                        "clarifications",
                        "setup_effects",
                        "rules_reference_ids",
                        "rules_integration",
                        "rule_surfaces",
                        "objective_tokens",
                        "runtime_state_requirements",
                        "search_tags",
                        "source_refs"
                    ],
                    "properties": {
                        "kind": {
                            "const": "objective_card"
                        },
                        "objective_name": {
                            "type": "string"
                        },
                        "category": {
                            "$ref": "#/definitions/objective_category"
                        },
                        "victory_token_points": {
                            "type": [
                                "integer",
                                "null"
                            ],
                            "minimum": 0
                        },
                        "task_force_recommended": {
                            "type": "boolean"
                        },
                        "setup_text": {
                            "type": "string"
                        },
                        "special_rule_text": {
                            "type": "string"
                        },
                        "end_of_round_text": {
                            "type": "string"
                        },
                        "end_of_game_text": {
                            "type": "string"
                        },
                        "timing_notes": {
                            "$ref": "#/definitions/note_array"
                        },
                        "errata": {
                            "$ref": "#/definitions/note_array"
                        },
                        "clarifications": {
                            "$ref": "#/definitions/note_array"
                        },
                        "setup_effects": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "additionalProperties": true
                            }
                        },
                        "objective_tokens": {
                            "$ref": "#/definitions/objective_tokens"
                        }
                    },
                    "additionalProperties": true
                }
            ]
        },
        "obstacle_component": {
            "allOf": [
                {
                    "$ref": "#/definitions/common_catalog_metadata"
                },
                {
                    "type": "object",
                    "required": [
                        "data_key",
                        "kind",
                        "obstacle_name",
                        "obstacle_type",
                        "token_image",
                        "wave",
                        "expansion",
                        "available_through",
                        "setup_constraints",
                        "rules_reference_ids",
                        "rules_integration",
                        "search_tags",
                        "source_refs"
                    ],
                    "properties": {
                        "kind": {
                            "const": "obstacle_component"
                        },
                        "obstacle_name": {
                            "type": "string"
                        },
                        "obstacle_type": {
                            "type": "string",
                            "enum": [
                                "ASTEROID",
                                "DEBRIS",
                                "STATION",
                                "OBJECTIVE_TOKEN"
                            ]
                        },
                        "token_image": {
                            "type": "string"
                        },
                        "setup_constraints": {
                            "$ref": "#/definitions/string_array"
                        },
                        "shape_metadata": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "additionalProperties": true
                }
            ]
        },
        "rules_reference": {
            "type": "object",
            "required": [
                "data_key",
                "kind",
                "scope",
                "display_name",
                "category",
                "rules_text",
                "summary",
                "search_tags",
                "source_refs",
                "implemented_rule_ids",
                "implementation_status"
            ],
            "properties": {
                "data_key": {
                    "type": "string"
                },
                "kind": {
                    "const": "rules_reference"
                },
                "scope": {
                    "$ref": "#/definitions/rules_scope"
                },
                "display_name": {
                    "type": "string"
                },
                "category": {
                    "type": "string"
                },
                "rules_text": {
                    "type": "string"
                },
                "summary": {
                    "type": "string"
                },
                "search_tags": {
                    "$ref": "#/definitions/string_array"
                },
                "source_refs": {
                    "$ref": "#/definitions/string_array"
                },
                "implemented_rule_ids": {
                    "$ref": "#/definitions/string_array"
                },
                "implementation_status": {
                    "$ref": "#/definitions/rules_integration_status"
                }
            },
            "additionalProperties": true
        }
    }
}
